# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your-telegram-bot-token-here
# Comma-separated Telegram user IDs allowed to use the bot (leave empty = open)
ALLOWED_USER_IDS=123456789,987654321

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Google Sheets ───────────────────────────────────────────────────────────
SHEET_ID=your-google-sheet-id-here
# Paste the entire service account JSON as a single-line string (no newlines)
SHEET_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ─── Database ────────────────────────────────────────────────────────────────
# Railway auto-injects this when you link a Postgres service.
# For local dev, leave unset to use SQLite, or set a postgres:// URL.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string-in-production

# ─── Server ──────────────────────────────────────────────────────────────────
# Railway injects PORT automatically. Only set this for local dev overrides.
PORT=8000
